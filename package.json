{
  "name": "extension-lockfile",
  "displayName": "Extension Lockfile",
  "description": "Lock and reproduce VS Code extension versions per workspace",
  "version": "0.0.2",
  "publisher": "your-publisher-id",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/extension-lockfile.git"
  },
  "homepage": "https://github.com/your-org/extension-lockfile#readme",
  "bugs": {
    "url": "https://github.com/your-org/extension-lockfile/issues"
  },
  "keywords": [
    "vscode",
    "extensions",
    "lockfile",
    "workspace",
    "team"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:extensionLockfile.generate",
    "onCommand:extensionLockfile.validate",
    "onCommand:extensionLockfile.installMissing"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extensionLockfile.generate",
        "title": "Extension Lockfile: Generate Lockfile"
      },
      {
        "command": "extensionLockfile.validate",
        "title": "Extension Lockfile: Validate Against Lockfile"
      },
      {
        "command": "extensionLockfile.installMissing",
        "title": "Extension Lockfile: Install Missing Extensions"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
